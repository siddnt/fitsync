{
  "name": "fitsync",
  "version": "1.0.0",
  "description": "gym management - fitsync",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --ignore 'node_modules/' src/index.js",
    "start": "node src/index.js",
    "test": "node src/scripts/runJest.mjs",
    "test:report": "node src/scripts/runJest.mjs --runInBand --coverage --json --outputFile reports/jest/results.json",
    "test:ci": "node src/scripts/runJest.mjs --runInBand --coverage",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:preview": "npm --prefix client run preview",
    "cache:benchmark": "node src/scripts/benchmarkCache.js",
    "load:test": "node src/scripts/loadTestPerformance.js",
    "db:analyze": "node src/scripts/analyzeQueryPlans.js",
    "search:sync": "node src/scripts/syncSearchIndexes.js",
    "docs:uml": "node src/scripts/renderUmlDiagrams.mjs",
    "docs:pdf": "python src/scripts/exportDddPdf.py",
    "seed:analytics": "node src/scripts/seedAdminAnalytics.js"
  },
  "author": "Sid",
  "license": "ISC",
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "supertest": "^7.1.1"
  },
  "dependencies": {
    "autocannon": "^8.0.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.3",
    "bullmq": "^5.73.5",
    "cloudinary": "^2.9.0",
    "colors": "^1.4.0",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.57.0",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "redis": "^5.11.0",
    "stripe": "^17.5.0",
    "swagger-ui-dist": "^5.32.2"
  }
}
